+#include <Library/UefiRuntimeServicesTableLib.h>
+
 #include "BootManagerMenu.h"
 
 EFI_HII_HANDLE  gStringPackHandle;
@@ -344,9 +346,9 @@ IgnoreBootOption (
   }
 
   //
-  // Ignore the hidden/inactive boot option.
+  // Ignore "UEFI Misc Device" boot options.
   //
-  if (((BootOption->Attributes & LOAD_OPTION_HIDDEN) != 0) || ((BootOption->Attributes & LOAD_OPTION_ACTIVE) == 0)) {
+  if (BootOption->Description != NULL && StrnCmp (BootOption->Description, L"UEFI Misc Device", 16) == 0) {
     return TRUE;
