		pmic_arbiter: arbiter@c400000 {
			compatible = "qcom,canoe-spmi-pmic-arb";
			reg = <0x00 0xc400000 0x00 0x3000 0x00 0xc900000 0x00 0x400000 0x00 0xc4c0000 0x00 0x400000 0x00 0xc403000 0x00 0x8000>;
			reg-names = "core", "chnls", "obsrvr", "chnl_map";
			#address-cells = <0x02>;
			#size-cells = <0x02>;
			ranges;
			qcom,channel = <0x00>;
			qcom,ee = <0x00>;
			phandle = <0x110>;

			spmi0_bus: spmi@c426000 {
				reg = <0x00 0xc426000 0x00 0x4000 0x00 0xc8c0000 0x00 0x10000 0x00 0xc42a000 0x00 0x8000>;
				reg-names = "cnfg", "intr", "chnl_owner";
				interrupts-extended = <0x30 0x01 0x04>;
				interrupt-names = "periph_irq";
				interrupt-controller;
				#interrupt-cells = <0x04>;
				#address-cells = <0x02>;
				#size-cells = <0x00>;
				phandle = <0x498>;

				qcom,pmk8550@0 {
					compatible = "qcom,spmi-pmic";
					reg = <0x00 0x00>;
					#address-cells = <0x01>;
					#size-cells = <0x00>;
					phandle = <0x6f0>;

					sdam@7000 {
						compatible = "qcom,spmi-sdam";
						reg = <0x7000>;
						#address-cells = <0x01>;
						#size-cells = <0x01>;
						phandle = <0x6f1>;

						smb1510_present@5d {
							reg = <0x5d 0x01>;
							bits = <0x05 0x05>;
							phandle = <0x6f2>;
						};

						ocp-log@76 {
							reg = <0x76 0x06>;
							phandle = <0x671>;
						};
					};

					sdam@7100 {
						compatible = "qcom,spmi-sdam";
						reg = <0x7100>;
						#address-cells = <0x01>;
						#size-cells = <0x01>;
						phandle = <0x6f3>;

						restart@48 {
							reg = <0x48 0x01>;
							bits = <0x01 0x07>;
							phandle = <0x67d>;
						};

						wr_thermal-flag@58 {
							reg = <0x58 0x01>;
							phandle = <0x6f4>;
						};

						alarm-log@76 {
							reg = <0x76 0x06>;
							phandle = <0x6f5>;
						};

						fmd-set@9a {
							reg = <0x9a 0x01>;
							phandle = <0x6f6>;
						};

						fmd-chg-pon@9f {
							reg = <0x9f 0x01>;
							phandle = <0x6f7>;
						};

						fmd-cnt2-stop@a2 {
							reg = <0xa2 0x01>;
							phandle = <0x6f8>;
						};

						bob1-off-mode-enable@50 {
							reg = <0x50 0x01>;
							phandle = <0x6e8>;
						};

						xo_calib-data@59 {
							reg = <0x59 0x01>;
							phandle = <0x6f9>;
						};
					};

					sdam@7400 {
						compatible = "qcom,spmi-sdam";
						reg = <0x7400>;
						phandle = <0x66f>;
					};

					sdam@7500 {
						compatible = "qcom,spmi-sdam";
						reg = <0x7500>;
						phandle = <0x670>;
					};

					sdam@7c00 {
						compatible = "qcom,spmi-sdam";
						reg = <0x7c00>;
						phandle = <0x68e>;
					};

					sdam@7d00 {
						compatible = "qcom,spmi-sdam";
						reg = <0x7d00>;
						phandle = <0x68f>;
					};

					sdam@8400 {
						compatible = "qcom,spmi-sdam";
						reg = <0x8400>;
						phandle = <0x66b>;
					};

					sdam@8500 {
						compatible = "qcom,spmi-sdam";
						reg = <0x8500>;
						phandle = <0x66c>;
					};

					sdam@9800 {
						compatible = "qcom,spmi-sdam";
						reg = <0x9800>;
						phandle = <0x690>;
					};

					sdam@9a00 {
						compatible = "qcom,spmi-sdam";
						reg = <0x9a00>;
						#address-cells = <0x01>;
						#size-cells = <0x01>;
						phandle = <0x6fa>;

						sqm-timer@b8 {
							reg = <0xb8 0x02>;
							phandle = <0x691>;
						};
					};

					sdam@9d00 {
						compatible = "qcom,spmi-sdam";
						reg = <0x9d00>;
						phandle = <0x6fb>;
					};

					sdam@b600 {
						compatible = "qcom,spmi-sdam";
						reg = <0xb600>;
						phandle = <0x6fc>;

						usb-mode@50 {
							reg = <0x50 0x01>;
							phandle = <0x68c>;
						};
					};

					pon_hlos@1300 {
						compatible = "qcom,pm8998-pon";
						reg = <0x1300 0x800>;
						reg-names = "pon_hlos", "pon_pbs";

						pwrkey {
							compatible = "qcom,pmk8350-pwrkey";
							interrupts = <0x00 0x13 0x07 0x03>;
							linux,code = <0x74>;
						};

						resin {
							compatible = "qcom,pmk8350-resin";
							interrupts = <0x00 0x13 0x06 0x03>;
							linux,code = <0x73>;
							debounce = <0x3d09>;
						};
					};

					pinctrl@b800 {
						compatible = "qcom,pmk8550-gpio";
						reg = <0xb800>;
						gpio-controller;
						#gpio-cells = <0x02>;
						interrupt-controller;
						#interrupt-cells = <0x02>;
						phandle = <0x6fd>;

						sub_batt_conn_therm_gpio_default {
							pins = "gpio3";
							function = "normal";
							bias-high-impedance;
							bias-disable;
							phandle = <0x6d8>;
						};
					};

					rtc@6100 {
						compatible = "qcom,pmk8350-rtc";
						reg = <0x6100 0x6200>;
						reg-names = "rtc", "alarm";
						interrupts = <0x00 0x62 0x01 0x01>;
						phandle = <0x6fe>;
					};

					pmk8550-pwm {
						compatible = "qcom,pmk8550-pwm";
						#address-cells = <0x01>;
						#size-cells = <0x00>;
						#pwm-cells = <0x02>;
					};

					vadc@9000 {
						compatible = "qcom,spmi-adc5-gen3";
