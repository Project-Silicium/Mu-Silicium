			#size-cells = <0x00>;
			status = "disabled";
			phandle = <0x413>;
		};

		intc: interrupt-controller@17000000 {
			compatible = "arm,gic-v3";
			#interrupt-cells = <0x03>;
			interrupt-controller;
			ranges;
			#redistributor-regions = <0x01>;
			redistributor-stride = <0x00 0x40000>;
			reg = <0x00 0x17000000 0x00 0x10000 0x00 0x17080000 0x00 0x200000>;
			interrupts = <0x01 0x09 0x04>;
			#address-cells = <0x01>;
			#size-cells = <0x01>;
			phandle = <0x01>;

			gic_its: msi-controller@17040000 {
