		};

		memtimer: timer@17810000 {
			#address-cells = <0x01>;
			#size-cells = <0x01>;
			ranges;
			compatible = "arm,armv7-timer-mem";
			reg = <0x00 0x17810000 0x00 0x1000>;
			clock-frequency = <0x124f800>;
			phandle = <0x414>;

			frame@17811000 {
				frame-number = <0x00>;
				interrupts = <0x00 0x08 0x04 0x00 0x06 0x04>;
				reg = <0x17811000 0x1000 0x17812000 0x1000>;
			};

			frame@17813000 {
				frame-number = <0x01>;
				interrupts = <0x00 0x09 0x04>;
				reg = <0x17813000 0x1000>;
				status = "disabled";
			};

			frame@17815000 {
				frame-number = <0x02>;
				interrupts = <0x00 0x0a 0x04>;
				reg = <0x17815000 0x1000>;
				status = "disabled";
			};

			frame@17817000 {
				frame-number = <0x03>;
				interrupts = <0x00 0x0b 0x04>;
				reg = <0x17817000 0x1000>;
				status = "disabled";
			};

			frame@17819000 {
				frame-number = <0x04>;
				interrupts = <0x00 0x0c 0x04>;
				reg = <0x17819000 0x1000>;
				status = "disabled";
			};

			frame@1781b000 {
				frame-number = <0x05>;
				interrupts = <0x00 0x0d 0x04>;
				reg = <0x1781b000 0x1000>;
				status = "disabled";
			};

			frame@1781d000 {
				frame-number = <0x06>;
				interrupts = <0x00 0x0e 0x04>;
				reg = <0x1781d000 0x1000>;
				status = "disabled";
			};
		};

