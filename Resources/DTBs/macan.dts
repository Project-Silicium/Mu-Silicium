						#address-cells = <0x01>;
						#size-cells = <0x00>;
						interrupt-names = "adc-sdam0", "adc-sdam1";
						interrupts = <0x00 0x90 0x01 0x01 0x00 0x91 0x01 0x01>;
						#thermal-sensor-cells = <0x01>;
						#io-channel-cells = <0x01>;
