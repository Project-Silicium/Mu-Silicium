			reusable;
			alignment = <0x00 0x400000>;
			size = <0x00 0x1400000>;
			phandle = <0x27>;
		};

		qseecom_ta_mem: qseecom_ta_region {
			compatible = "shared-dma-pool";
			alloc-ranges = <0x00 0x00 0x00 0xffffffff>;
			reusable;
			alignment = <0x00 0x400000>;
			size = <0x00 0x2000000>;
			phandle = <0x28>;
		};

		dump_mem: dump_mem_region {
			alloc-ranges = <0x01 0x00 0xfffffffe 0xffffffff>;
			size = <0x00 0x5e00000>;
			phandle = <0x112>;
		};

		botloader_mem@0x81CE4000 {
			reg = <0x00 0x81ce4000 0x00 0x10000>;
			label = "bootloader_log_mem";
			phandle = <0x69b>;
		};

		device_info_mem@0xA7F00000 {
			reg = <0x00 0xa7f00000 0x00 0x8000>;
			label = "dump_device_info_mem";
			phandle = <0x69c>;
		};

		splash_region {
			phandle = <0x9ad>;
			label = "cont_splash_region";
			reg = <0x00 0xfc800000 0x00 0x2b00000>;
		};
	};

	mem-offline {
		compatible = "qcom,mem-offline";
		offline-sizes = <0x02 0xc0000000 0x01 0x00>;
		granule = <0x400>;
		qcom,qmp = <0x03>;
		status = "disabled";
	};

	firmware: firmware {
		phandle = <0x3a7>;

		qcom_scm: qcom_scm {
			compatible = "qcom,scm-v1.1", "qcom,scm";
			qcom,dload-mode = <0x04 0x19000>;
			phandle = <0x25>;
			qcom,max-queues = <0x23>;
			interrupts = <0x00 0x3c2 0x01>;
		};

		qcom,sps {
			compatible = "qcom,msm-sps-4k";
			qcom,pipe-attr-ee;
		};

		qcom_smcinvoke {
			compatible = "qcom,smcinvoke";
		};

		qcom_mem_object {
			compatible = "qcom,mem-object";
		};

		qtee_shmbridge {
			compatible = "qcom,tee-shared-memory-bridge";
		};

		sdei {
			compatible = "arm,sdei-1.0";
			method = "hvc";
		};

		qcom,hdcp {
			compatible = "qcom,hdcp";
			qcom,use-smcinvoke = <0x01>;
		};

		qti,smmu-proxy {
			compatible = "smmu-proxy-sender";
		};

		qcom,seccamtest {
			compatible = "qcom,seccamtest";
			qti,smmu-proxy-cb-id = <0x00>;
		};
	};

	cpus {
		#address-cells = <0x02>;
		#size-cells = <0x00>;

		CPU0: cpu@0 {
			device_type = "cpu";
			compatible = "arm,armv8";
			reg = <0x00 0x00>;
			enable-method = "psci";
			cpu-idle-states = <0x05>;
			power-domains = <0x06>;
			power-domain-names = "psci";
			#cooling-cells = <0x02>;
			clocks = <0x07 0x00>;
			capacity-dmips-mhz = <0x400>;
			dynamic-power-coefficient = <0x64>;
			next-level-cache = <0x08>;
			phandle = <0x12>;

			L2_0: l2-cache {
				compatible = "cache";
				cache-level = <0x02>;
				phandle = <0x08>;
			};
		};

		CPU1: cpu@100 {
			device_type = "cpu";
			compatible = "arm,armv8";
			reg = <0x00 0x100>;
			enable-method = "psci";
			cpu-idle-states = <0x05>;
			power-domains = <0x09>;
