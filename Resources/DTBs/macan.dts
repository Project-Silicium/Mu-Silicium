						pmk8550_vref_1p25 {
							reg = <0x01>;
							label = "pmk8550_vref_1p25";
							qcom,pre-scaling = <0x01 0x01>;
						};

						pmk8550_die_temp {
							reg = <0x03>;
							label = "pmk8550_die_temp";
							qcom,pre-scaling = <0x01 0x01>;
						};

						pm8550_offset_ref {
							reg = <0x100>;
							label = "pm8550_offset_ref";
							qcom,pre-scaling = <0x01 0x01>;
						};

						pm8550_vref_1p25 {
							reg = <0x101>;
							label = "pm8550_vref_1p25";
