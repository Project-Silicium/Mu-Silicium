			lpass_cdc: lpass-cdc {
				phandle = <0x627>;
				clocks = <0x61e 0x00 0x61f 0x00>;
				clock-names = "lpass_core_hw_vote", "lpass_audio_hw_vote";
				compatible = "qcom,lpass-cdc";
				qcom,lpass-cdc-version = <0x07>;
				qcom,num-macros = <0x03>;
				#size-cells = <0x01>;
				#address-cells = <0x01>;

