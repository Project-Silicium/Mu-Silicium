		qup1_gpi_iommu_region: qup1_gpi_iommu_region {
			iommu-addresses = <0x28e 0x00 0x00 0x00 0x100000 0x28e 0x00 0x200000 0xffffffff 0xffe00000>;
			phandle = <0x28f>;
		};

		gpi_dma1: qcom,gpi-dma@a00000 {
			compatible = "qcom,gpi-dma";
			#dma-cells = <0x05>;
			reg = <0x00 0xa00000 0x00 0x60000>;
			reg-names = "gpi-top";
			iommus = <0x23 0xb6 0x00>;
			qcom,max-num-gpii = <0x0c>;
			interrupts = <0x00 0x344 0x04 0x00 0x345 0x04 0x00 0x346 0x04 0x00 0x347 0x04 0x00 0x348 0x04 0x00 0x349 0x04 0x00 0x34a 0x04 0x00 0x34b 0x04 0x00 0x34c 0x04 0x00 0x34d 0x04 0x00 0x34e 0x04 0x00 0x34f 0x04>;
			qcom,static-gpii-mask = <0x01>;
			qcom,gpii-mask = <0x0e>;
			qcom,ev-factor = <0x01>;
			memory-region = <0x28f>;
			qcom,gpi-ee-offset = <0x10000>;
			dma-coherent;
			status = "ok";
			phandle = <0x28e>;
		};

		qup1_se_iommu_region: qup1_se_iommu_region {
			iommu-addresses = <0x290 0x00 0x00 0x00 0x40000000 0x290 0x00 0x50000000 0xffffffff 0xb0000000>;
			phandle = <0x291>;
		};

		qupv3_1: qcom,qupv3_1_geni_se@ac0000 {
			compatible = "qcom,geni-se-qup";
			reg = <0x00 0xac0000 0x00 0x2000>;
			#address-cells = <0x01>;
			#size-cells = <0x01>;
			clock-names = "m-ahb", "s-ahb";
			clocks = <0x2f 0x89 0x2f 0x8a>;
			iommus = <0x23 0xa3 0x00>;
			memory-region = <0x291>;
			qcom,iommu-geometry = <0x00 0x40000000 0x00 0x10000000>;
			qcom,iommu-dma = "fastmap";
			dma-coherent;
			ranges;
			status = "ok";
			phandle = <0x290>;

			qupv3_se0_i2c: i2c@a80000 {
				compatible = "qcom,i2c-geni";
				reg = <0xa80000 0x4000>;
				#address-cells = <0x01>;
				#size-cells = <0x00>;
				interrupts = <0x00 0x33c 0x04>;
				clock-names = "se-clk";
				clocks = <0x2f 0x56>;
				interconnect-names = "qup-core", "qup-config", "qup-memory";
				interconnects = <0x292 0x2a 0x292 0x233 0x1b 0x02 0x8a 0x213 0x89 0x05 0x1c 0x200>;
				pinctrl-names = "default", "sleep";
				pinctrl-0 = <0x293 0x294>;
				pinctrl-1 = <0x295>;
				dmas = <0x28e 0x00 0x00 0x03 0x40 0x00 0x28e 0x01 0x00 0x03 0x40 0x00>;
				dma-names = "tx", "rx";
				status = "ok";
				phandle = <0x52b>;
				qcom,clk-freq-out = <0x61a80>;

				nq@28 {
					compatible = "qcom,sn-nci";
					reg = <0x28>;
					qcom,sn-irq = <0x2a 0x2f 0x00>;
					qcom,sn-ven = <0x2a 0x22 0x00>;
					qcom,sn-clkreq = <0x2a 0x23 0x00>;
					nxp,sn-vbat = <0x2a 0x16 0x00>;
					qcom,sn-vdd-1p8-supply = <0x441>;
					qcom,sn-vdd-1p8-voltage = <0x124f80 0x124f80>;
					qcom,sn-vdd-1p8-current = <0x26548>;
					qcom,sn-szone = "enable";
					interrupt-parent = <0x2a>;
					nvmem-cells = <0x6e8>;
					nvmem-cell-names = "nfc_bob1_cell";
					interrupts = <0x2f 0x00>;
					interrupt-names = "nfc_irq";
					pinctrl-names = "nfc_active", "nfc_suspend";
					pinctrl-0 = <0x6e9 0x6ea 0x6eb>;
					pinctrl-1 = <0x6ec 0x6ed 0x6ee>;
