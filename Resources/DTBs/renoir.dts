			qcom,codec-ext-clk-src = <0x0a>;
			qcom,codec-lpass-ext-clk-freq = <0x124f800>;
			qcom,codec-lpass-clk-id = <0x310>;
			#clock-cells = <0x01>;
			phandle = <0x5ce>;
		};

		msm_cdc_pinctrl@6 {
			compatible = "qcom,msm-cdc-pinctrl";
			pinctrl-names = "aud_active", "aud_sleep";
			pinctrl-0 = <0x5dc>;
			pinctrl-1 = <0x5dd>;
			#gpio-cells = <0x00>;
			phandle = <0x5db>;
		};

		qcom,camera-flash@0 {
			cell-index = <0x00>;
			compatible = "qcom,camera-flash";
			flash-source = <0x5de>;
			torch-source = <0x5df>;
			switch-source = <0x5e0>;
			status = "ok";
			phandle = <0x5e5>;
		};

		qcom,camera-flash@1 {
			cell-index = <0x01>;
			compatible = "qcom,camera-flash";
			flash-source = <0x5de>;
			torch-source = <0x5df>;
			switch-source = <0x5e0>;
			status = "ok";
			phandle = <0x5f7>;
		};

		qcom,camera-flash@2 {
			cell-index = <0x02>;
			compatible = "qcom,camera-flash";
			flash-source = <0x5de>;
			torch-source = <0x5df>;
			switch-source = <0x5e0>;
			status = "ok";
			phandle = <0x5f1>;
		};

		gpio-regulator@0 {
			compatible = "regulator-fixed";
			reg = <0x00 0x00>;
			regulator-name = "camera_front_vana_ldo";
			regulator-min-microvolt = <0x2ab980>;
			regulator-max-microvolt = <0x2ab980>;
			regulator-enable-ramp-delay = <0x87>;
			enable-active-high;
			gpio = <0x40 0xb0 0x00>;
			phandle = <0x5ec>;
		};

		gpio-regulator@1 {
			compatible = "regulator-fixed";
			reg = <0x01 0x00>;
			regulator-name = "camera_front_vdig_ldo";
			regulator-min-microvolt = <0x100590>;
			regulator-max-microvolt = <0x100590>;
			regulator-enable-ramp-delay = <0x87>;
			enable-active-high;
			gpio = <0x40 0xb1 0x00>;
			phandle = <0x5eb>;
		};

		qcom,cam-res-mgr {
			compatible = "qcom,cam-res-mgr";
			status = "ok";
		};

		fingerprint_fpc {
			status = "ok";
			compatible = "fpc,fpc1020";
			interrupt-parent = <0x40>;
			interrupts = <0x26 0x00>;
			fpc,gpio_rst = <0x40 0x27 0x00>;
			fpc,gpio_irq = <0x40 0x26 0x00>;
			fp_vdd_vreg-supply = <0x2f5>;
			pinctrl-names = "fpc1020_reset_reset", "fpc1020_reset_active", "fpc1020_irq_active";
			pinctrl-0 = <0x603>;
			pinctrl-1 = <0x604>;
			pinctrl-2 = <0x605>;
		};

		md_testing_mode {
			compatible = "modem,md-testing-mode";
			status-gpio = <0x40 0x0b 0x00 0x40 0x0e 0x00>;
			debounce-time = <0x1e>;
			pinctrl-names = "default";
			pinctrl-0 = <0x606 0x607>;
		};
	};

