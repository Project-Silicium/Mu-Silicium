			alignment = <0x00 0x400000>;
			size = <0x00 0x1c00000>;
			phandle = <0x127>;
		};

		splash_region {
			reg = <0x00 0xe1000000 0x00 0x2300000>;
			label = "cont_splash_region";
			phandle = <0x2c8>;
		};

		dfps_data_memory {
			reg = <0x00 0xe3300000 0x00 0x100000>;
			label = "dfps_data_memory";
			phandle = <0x224>;
		};
